#!/bin/bash
#
# PostgreSQL Database Diagnostic Tool (pg)
# Production-ready for PostgreSQL 9.6-18
#
# Version: 3.0.0 (2026-03-16)
# Author: Kevin
#

readonly TOOL_VERSION="3.0.0"
readonly TOOL_BUILD_DATE="2026-03-16"

PG_VERSION=""
PG_MAJOR_VERSION=""
PGS_TOTAL_COL=""
PGS_MEAN_COL=""
PGS_MAX_COL=""
EXEC_NAME=$(basename "$0")
DBHOST="${PGHOST:-localhost}"
DBPORT="${PGPORT:-5432}"
DBUSER="${PGUSER:-postgres}"
DBNAME="${PGDATABASE:-postgres}"
DBPASSWORD="${PGPASSWORD:-}"
TOP_N=10
USE_PASSWORD_FILE=""

setup_password()
{
  if [ -n "$PGPASSWORD" ]; then
    export PGPASSWORD="$PGPASSWORD"
    return 0
  fi

  if [ -n "$USE_PASSWORD_FILE" ] && [ -f "$USE_PASSWORD_FILE" ]; then
    chmod 600 "$USE_PASSWORD_FILE" 2>/dev/null || true
    DBPASSWORD=$(cat "$USE_PASSWORD_FILE")
    export PGPASSWORD="$DBPASSWORD"
    return 0
  fi

  local pgpass_file="$HOME/.pgpass"
  if [ -f "$pgpass_file" ]; then
    chmod 600 "$pgpass_file" 2>/dev/null || true
    export PGPASSFILE="$pgpass_file"
    return 0
  fi

  local local_pgpass="$(pwd)/.pgpass"
  if [ -f "$local_pgpass" ]; then
    chmod 600 "$local_pgpass" 2>/dev/null || true
    export PGPASSFILE="$local_pgpass"
    return 0
  fi
}

setup_password

use_color=true
[ ! -t 1 ] || [ "$TERM" = "dumb" ] && use_color=false

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

colorize()
{
  local color=$1 text="$2"
  [ "$use_color" = true ] || { echo "$text"; return; }
  case "$color" in
    red)    printf "${RED}%s${NC}\n" "$text" ;;
    green)  printf "${GREEN}%s${NC}\n" "$text" ;;
    yellow) printf "${YELLOW}%s${NC}\n" "$text" ;;
    blue)   printf "${BLUE}%s${NC}\n" "$text" ;;
    *)      echo "$text" ;;
  esac
}

get_version()
{
  local version_output
  version_output=$(psql -h "$DBHOST" -p "$DBPORT" -U "$DBUSER" -d "$DBNAME" -t -A -c "SELECT version();" 2>/dev/null)

  if [ $? -eq 0 ] && [ -n "$version_output" ]; then
    PG_VERSION=$(echo "$version_output" | sed -n 's/^PostgreSQL \([0-9.]*\).*/\1/p' | head -1)
    PG_MAJOR_VERSION=$(echo "$PG_VERSION" | cut -d. -f1)
  else
    echo "Error: Could not connect to PostgreSQL"
    exit 1
  fi
}

init_pg_stat_statements_columns()
{
  [ -n "$PGS_TOTAL_COL" ] && return 0

  local rel_exists
  rel_exists=$(echo "SELECT 1 FROM pg_class WHERE relname = 'pg_stat_statements' AND relkind IN ('v','r');" | $PSQL_CMD -t -A 2>/dev/null)
  [ -z "$rel_exists" ] && return 1

  local has_new
  has_new=$(echo "SELECT 1 FROM pg_attribute WHERE attrelid = 'pg_stat_statements'::regclass AND attname = 'total_exec_time';" | $PSQL_CMD -t -A 2>/dev/null)
  if [ -n "$has_new" ]; then
    PGS_TOTAL_COL="total_exec_time"
    PGS_MEAN_COL="mean_exec_time"
    PGS_MAX_COL="max_exec_time"
  else
    PGS_TOTAL_COL="total_time"
    PGS_MEAN_COL="mean_time"
    PGS_MAX_COL="max_time"
  fi
}

extension_installed()
{
  local ext="$1"
  echo "SELECT 1 FROM pg_extension WHERE extname = '$ext';" | $PSQL_CMD -t -A 2>/dev/null
}

run_stat_statements()
{
  local query="$1"
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed."
    echo "Run: CREATE EXTENSION pg_stat_statements;"
    return 1
  fi
  init_pg_stat_statements_columns
  echo "$query" | $PSQL_CMD
}

usage()
{
  cat << EOF
${BLUE}PostgreSQL Database Diagnostic Tool${NC}
Version: $TOOL_VERSION | Build: $TOOL_BUILD_DATE

Usage: $EXEC_NAME [options] <command> [arguments]

Options:
  -h, --host <host>         Database host (default: localhost)
  -p, --port <port>         Database port (default: 5432)
  -u, --user <user>         Database user (default: postgres)
  -d, --dbname <name>       Database name (default: postgres)
  -P, --password-file <file> Password file
  -n, --top <num>           Limit output (default: 10)

Commands:

  === QUICK DIAGNOSTICS (Most Used) ===
    ps                      Process list (all sessions)
    running [N]             Active queries
    blocking                Who is blocking whom
    locks                   Lock overview
    kill <pid>              Terminate session
    cancel <pid>            Cancel query
    sql <pid>               Show full SQL text

  === SLOW QUERY ANALYSIS ===
    slow [seconds]          Queries running > N seconds (default: 5)
    top_time [N]            Top queries by total time
    top_calls [N]           Top queries by call count
    top_io [N]              Top queries by I/O
    query_history [N]       Recent query statistics

  === TABLE & INDEX ===
    table_size [pattern]    Table sizes (optional: schema.table%)
    index_size [pattern]    Index sizes
    bloat                   Table bloat analysis
    unused_indexes          Unused indexes (safe to drop)
    duplicate_indexes       Redundant indexes
    missing_indexes         Suggested indexes

  === VACUUM & MAINTENANCE ===
    vacuum_status           Last vacuum/analyze times
    dead_tuples             Tables with dead tuples
    vacuum_progress         Running vacuum operations

  === CONNECTIONS ===
    conn                    Connection summary
    conn_limit              Connection limits per user/db
    idle_tx                 Idle in transaction sessions

  === PERFORMANCE ===
    cache_hit               Cache hit ratios
    io_stats                I/O statistics
    wait_events             Wait event summary
    temp_files              Temporary file usage

  === REPLICATION ===
    repl                    Replication status
    repl_lag                Replication lag details
    slot                    Replication slots

  === WAL & CHECKPOINT ===
    wal                     WAL position info
    checkpoint              Checkpoint statistics

  === SIZE & STORAGE ===
    db_size                 Database sizes
    ts_size                 Tablespace sizes
    schema_size             Schema sizes

  === CONFIGURATION ===
    config [pattern]        Show settings (optional filter)
    config_diff             Non-default settings
    reload                  Reload configuration

  === SCHEMA INFO ===
    tables [pattern]        List tables
    indexes [pattern]       List indexes
    views [pattern]         List views
    functions [pattern]     List functions
    triggers [pattern]      List triggers
    fks                     Foreign keys
    pks                     Primary keys
    constraints             All constraints

  === SECURITY ===
    users                   List users
    roles                   List roles
    permissions             Object permissions

  === HEALTH CHECK ===
    health                  Quick health check
    overview                System overview
    uptime                  Server uptime

  === UTILITY ===
    version                 PostgreSQL version
    ext                     Installed extensions
    set_config <name> <val> Change setting (session)
    watch <sec> <cmd>       Repeat command every N seconds

Examples:
  $EXEC_NAME ps
  $EXEC_NAME slow 10
  $EXEC_NAME table_size public.%
  $EXEC_NAME top_time 20
  $EXEC_NAME watch 5 running

Environment: PGHOST, PGPORT, PGUSER, PGDATABASE, PGPASSWORD
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--host)     DBHOST="$2"; shift 2 ;;
    -p|--port)     DBPORT="$2"; shift 2 ;;
    -u|--user)     DBUSER="$2"; shift 2 ;;
    -d|--dbname)   DBNAME="$2"; shift 2 ;;
    -P|--password-file) USE_PASSWORD_FILE="$2"; shift 2 ;;
    -n|--top)      TOP_N="$2"; shift 2 ;;
    --help)        usage ;;
    *)             break ;;
  esac
done

if [ -n "$PGPASSWORD" ] || [ -n "$PGPASSFILE" ] || [ -n "$USE_PASSWORD_FILE" ]; then
  PSQL_CMD="psql -h $DBHOST -p $DBPORT -U $DBUSER -d $DBNAME -w"
else
  PSQL_CMD="psql -h $DBHOST -p $DBPORT -U $DBUSER -d $DBNAME"
fi

get_version

[ $# -lt 1 ] && usage

COMMAND="$1"
shift

q()
{
  echo "$1" | $PSQL_CMD
}

q_sanitize()
{
  echo "$1" | sed "s/'/''/g" | sed 's/[^a-zA-Z0-9_ %.-]/_/g'
}

# ============================================
# QUICK DIAGNOSTICS
# ============================================

cmd_ps()
{
  local limit=${1:-50}
  q "SELECT pid, usename, application_name, client_addr::text, state, 
       CASE WHEN state = 'active' THEN now()-query_start ELSE NULL END AS duration,
       wait_event_type, wait_event, LEFT(query, 80) AS query
     FROM pg_stat_activity 
     WHERE state IS NOT NULL
     ORDER BY query_start DESC NULLS LAST 
     LIMIT $limit;"
}

cmd_running()
{
  local limit=${1:-$TOP_N}
  q "SELECT pid, usename, application_name, 
       now()-query_start AS duration, 
       wait_event_type, wait_event,
       LEFT(query, 120) AS query
     FROM pg_stat_activity 
     WHERE state = 'active' AND query NOT LIKE '%pg_stat_activity%'
     ORDER BY query_start LIMIT $limit;"
}

cmd_blocking()
{
  q "SELECT blocked.pid AS blocked_pid, blocked.usename AS blocked_user,
       blocking.pid AS blocking_pid, blocking.usename AS blocking_user,
       blocked.wait_event, 
       now() - blocked.query_start AS duration,
       LEFT(blocked.query, 80) AS blocked_query
     FROM pg_stat_activity blocked
     JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
     WHERE blocked.state = 'active';"
}

cmd_locks()
{
  q "SELECT l.locktype, l.mode, l.granted, a.pid, a.usename,
       COALESCE(c.relname, '') AS relation,
       LEFT(a.query, 60) AS query
     FROM pg_locks l
     JOIN pg_stat_activity a ON l.pid = a.pid
     LEFT JOIN pg_class c ON l.relation = c.oid
     WHERE l.relation IS NOT NULL OR l.locktype IN ('transactionid', 'virtualxid')
     ORDER BY l.granted, a.pid;"
}

cmd_kill()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME kill <pid>"; return 1; }
  [[ ! "$pid" =~ ^[0-9]+$ ]] && { echo "Error: PID must be numeric"; return 1; }
  q "SELECT pg_terminate_backend($pid) AS result;"
}

cmd_cancel()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME cancel <pid>"; return 1; }
  [[ ! "$pid" =~ ^[0-9]+$ ]] && { echo "Error: PID must be numeric"; return 1; }
  q "SELECT pg_cancel_backend($pid) AS result;"
}

cmd_sql()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME sql <pid>"; return 1; }
  q "SELECT pid, usename, state, now()-query_start AS duration, query FROM pg_stat_activity WHERE pid = $pid;"
}

# ============================================
# SLOW QUERY ANALYSIS
# ============================================

cmd_slow()
{
  local secs=${1:-5}
  q "SELECT pid, usename, application_name, client_addr::text,
       now()-query_start AS duration, state, wait_event,
       query
     FROM pg_stat_activity 
     WHERE state = 'active' 
       AND now()-query_start > interval '$secs seconds'
       AND query NOT LIKE '%pg_stat_activity%'
     ORDER BY query_start;"
}

cmd_top_time()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT LEFT(query, 100) AS query, calls, 
       round(${PGS_TOTAL_COL}/1000.0, 2) AS total_sec,
       round(${PGS_MEAN_COL}/1000.0, 4) AS mean_sec,
       rows
     FROM pg_stat_statements 
     ORDER BY ${PGS_TOTAL_COL} DESC LIMIT $limit;"
}

cmd_top_calls()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT LEFT(query, 100) AS query, calls, 
       round(${PGS_TOTAL_COL}/1000.0, 2) AS total_sec,
       round(${PGS_MEAN_COL}/1000.0, 4) AS mean_sec,
       rows
     FROM pg_stat_statements 
     ORDER BY calls DESC LIMIT $limit;"
}

cmd_top_io()
{
  local limit=${1:-$TOP_N}
  run_stat_statements "SELECT LEFT(query, 80) AS query, calls,
       shared_blks_read, shared_blks_hit,
       temp_blks_read, temp_blks_written
     FROM pg_stat_statements 
     WHERE shared_blks_read > 0 OR temp_blks_read > 0
     ORDER BY shared_blks_read + temp_blks_read DESC 
     LIMIT $limit;"
}

cmd_query_history()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT queryid, LEFT(query, 80) AS query, calls,
       round(${PGS_MEAN_COL}::numeric, 2) AS mean_ms,
       round(${PGS_MAX_COL}::numeric, 2) AS max_ms,
       rows, 
       shared_blks_hit + shared_blks_read AS blks
     FROM pg_stat_statements 
     ORDER BY calls DESC LIMIT $limit;"
}

# ============================================
# TABLE & INDEX
# ============================================

cmd_table_size()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, tablename, 
       pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) AS total_size,
       pg_size_pretty(pg_relation_size(schemaname||'.'||tablename)) AS table_size,
       pg_size_pretty(pg_indexes_size(schemaname||'.'||tablename)) AS index_size
     FROM pg_tables 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND tablename LIKE '%$sanitized%'
     ORDER BY pg_total_relation_size(schemaname||'.'||tablename) DESC 
     LIMIT $TOP_N;"
}

cmd_index_size()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, relname AS tablename, indexrelname AS indexname,
       pg_size_pretty(pg_relation_size(indexrelid)) AS size,
       idx_scan, idx_tup_read
     FROM pg_stat_user_indexes 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND indexrelname LIKE '%$sanitized%'
     ORDER BY pg_relation_size(indexrelid) DESC 
     LIMIT $TOP_N;"
}

cmd_bloat()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS tablename,
       n_live_tup AS live, n_dead_tup AS dead,
       CASE WHEN n_live_tup > 0 
         THEN round(100.0 * n_dead_tup / (n_live_tup + n_dead_tup), 2) 
         ELSE 0 END AS dead_pct,
       last_autovacuum, last_vacuum
     FROM pg_stat_user_tables 
     WHERE n_dead_tup > 0
     ORDER BY n_dead_tup DESC 
     LIMIT $limit;"
}

cmd_unused_indexes()
{
  q "SELECT schemaname, relname AS tablename, indexrelname AS indexname,
       pg_size_pretty(pg_relation_size(indexrelid)) AS size,
       idx_scan
     FROM pg_stat_user_indexes s
     JOIN pg_index i ON s.indexrelid = i.indexrelid
     WHERE idx_scan = 0 
       AND NOT i.indisprimary 
       AND NOT i.indisunique
       AND schemaname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY pg_relation_size(indexrelid) DESC;"
}

cmd_duplicate_indexes()
{
  q "SELECT n.nspname AS schema, t.relname AS table,
       i1.relname AS index1, i2.relname AS index2,
       pg_size_pretty(pg_relation_size(i2.oid)) AS wasted_size
     FROM pg_index idx1
     JOIN pg_index idx2 ON idx1.indrelid = idx2.indrelid
       AND idx1.indexrelid < idx2.indexrelid
       AND idx1.indkey = idx2.indkey
     JOIN pg_class t ON t.oid = idx1.indrelid
     JOIN pg_class i1 ON i1.oid = idx1.indexrelid
     JOIN pg_class i2 ON i2.oid = idx2.indexrelid
     JOIN pg_namespace n ON n.oid = t.relnamespace
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY t.relname;"
}

cmd_missing_indexes()
{
  q "SELECT schemaname, relname AS tablename,
       seq_scan, idx_scan,
       n_live_tup,
       CASE WHEN n_live_tup > 0 AND seq_scan > idx_scan 
         THEN 'HIGH' 
         WHEN seq_scan > 10 AND idx_scan = 0 
         THEN 'MEDIUM' 
         ELSE 'LOW' END AS need_index
     FROM pg_stat_user_tables 
     WHERE n_live_tup > 1000 AND seq_scan > 10
     ORDER BY seq_scan DESC 
     LIMIT $TOP_N;"
}

# ============================================
# VACUUM & MAINTENANCE
# ============================================

cmd_vacuum_status()
{
  q "SELECT schemaname, relname AS tablename,
       n_live_tup, n_dead_tup,
       last_vacuum, last_autovacuum,
       last_analyze, last_autoanalyze,
       vacuum_count + autovacuum_count AS total_vacuums
     FROM pg_stat_user_tables 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY n_dead_tup DESC 
     LIMIT 20;"
}

cmd_dead_tuples()
{
  cmd_bloat "$@"
}

cmd_vacuum_progress()
{
  q "SELECT pid, datname, relid::regclass AS table,
       phase, 
       heap_blks_total, heap_blks_scanned, heap_blks_vacuumed,
       num_dead_tuples
     FROM pg_stat_progress_vacuum;"
}

# ============================================
# CONNECTIONS
# ============================================

cmd_conn()
{
  q "SELECT state, count(*) AS count,
       count(*) * 100.0 / sum(count(*)) over() AS pct
     FROM pg_stat_activity 
     WHERE state IS NOT NULL
     GROUP BY state 
     ORDER BY count DESC;"
}

cmd_conn_limit()
{
  q "SELECT 'max_connections' AS setting, setting::int AS value FROM pg_settings WHERE name = 'max_connections'
     UNION ALL
     SELECT 'current_connections', count(*)::text FROM pg_stat_activity
     UNION ALL
     SELECT 'superuser_reserved', setting FROM pg_settings WHERE name = 'superuser_reserved_connections';"
  echo ""
  q "SELECT usename, val AS limit, cur AS current,
       CASE WHEN val > 0 AND cur >= val THEN 'LIMIT REACHED' ELSE 'OK' END AS status
     FROM (
       SELECT usename, 
         (SELECT setting::int FROM pg_settings WHERE name = 'max_connections') AS val,
         count(*) AS cur
       FROM pg_stat_activity GROUP BY usename
     ) x ORDER BY cur DESC;"
}

cmd_idle_tx()
{
  q "SELECT pid, usename, application_name, client_addr::text,
       now() - xact_start AS tx_duration,
       now() - query_start AS query_duration,
       state, LEFT(query, 100) AS query
     FROM pg_stat_activity 
     WHERE state = 'idle in transaction'
     ORDER BY xact_start;"
}

# ============================================
# PERFORMANCE
# ============================================

cmd_cache_hit()
{
  q "SELECT 'Database' AS level, datname,
       round(100.0 * blks_hit / nullif(blks_hit + blks_read, 0), 2) AS hit_ratio
     FROM pg_stat_database 
     WHERE datname NOT IN ('template0', 'template1')
     UNION ALL
     SELECT 'Table' AS level, schemaname||'.'||relname,
       round(100.0 * heap_blks_hit / nullif(heap_blks_hit + heap_blks_read, 0), 2)
     FROM pg_statio_user_tables 
     WHERE heap_blks_read + heap_blks_hit > 0
     ORDER BY hit_ratio ASC 
     LIMIT 20;"
}

cmd_io_stats()
{
  q "SELECT schemaname, relname AS table,
       heap_blks_read, heap_blks_hit,
       round(100.0 * heap_blks_hit / nullif(heap_blks_hit + heap_blks_read, 0), 2) AS hit_ratio
     FROM pg_statio_user_tables 
     WHERE heap_blks_read > 0
     ORDER BY heap_blks_read DESC 
     LIMIT $TOP_N;"
}

cmd_wait_events()
{
  q "SELECT wait_event_type, wait_event, count(*) AS sessions,
       array_agg(pid) AS pids
     FROM pg_stat_activity 
     WHERE wait_event IS NOT NULL 
       AND wait_event_type NOT IN ('Activity', 'Client')
     GROUP BY wait_event_type, wait_event 
     ORDER BY count DESC;"
}

cmd_temp_files()
{
  q "SELECT datname, temp_files, 
       pg_size_pretty(temp_bytes) AS temp_size,
       temp_bytes
     FROM pg_stat_database 
     WHERE temp_files > 0
     ORDER BY temp_bytes DESC;"
}

# ============================================
# REPLICATION
# ============================================

cmd_repl()
{
  q "SELECT pid, usename, application_name, client_addr,
       state, sync_state,
       pg_wal_lsn_diff(pg_current_wal_lsn(), replay_lsn) AS lag_bytes,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), replay_lsn)) AS lag
     FROM pg_stat_replication;"
}

cmd_repl_lag()
{
  q "SELECT client_addr, application_name, state, sync_state,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), sent_lsn)) AS sent_lag,
       pg_size_pretty(pg_wal_lsn_diff(sent_lsn, write_lsn)) AS write_lag,
       pg_size_pretty(pg_wal_lsn_diff(write_lsn, flush_lsn)) AS flush_lag,
       pg_size_pretty(pg_wal_lsn_diff(flush_lsn, replay_lsn)) AS replay_lag,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), replay_lsn)) AS total_lag
     FROM pg_stat_replication;"
}

cmd_slot()
{
  q "SELECT slot_name, slot_type, active, active_pid,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), restart_lsn)) AS retained_wal,
       safe_wal_size, wal_status
     FROM pg_replication_slots 
     ORDER BY active DESC;"
}

# ============================================
# WAL & CHECKPOINT
# ============================================

cmd_wal()
{
  q "SELECT pg_current_wal_lsn() AS current_lsn,
       pg_walfile_name(pg_current_wal_lsn()) AS wal_file,
       pg_wal_lsn_diff(pg_current_wal_lsn(), '0/0') AS total_bytes,
       pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), '0/0')) AS total_size,
       pg_is_in_recovery() AS in_recovery;"
}

cmd_checkpoint()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 17 ]; then
    q "SELECT 'timed' AS type, num_timed AS count FROM pg_stat_checkpointer
       UNION ALL SELECT 'requested', num_requested FROM pg_stat_checkpointer
       UNION ALL SELECT 'write_time_ms', write_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'sync_time_ms', sync_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'buffers_written', buffers_written::text FROM pg_stat_checkpointer;"
  else
    q "SELECT 'timed' AS type, checkpoints_timed AS count FROM pg_stat_bgwriter
       UNION ALL SELECT 'requested', checkpoints_req FROM pg_stat_bgwriter
       UNION ALL SELECT 'write_time_ms', checkpoint_write_time::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'sync_time_ms', checkpoint_sync_time::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'buffers_checkpoint', buffers_checkpoint::text FROM pg_stat_bgwriter;"
  fi
}

# ============================================
# SIZE & STORAGE
# ============================================

cmd_db_size()
{
  q "SELECT datname, pg_size_pretty(pg_database_size(datname)) AS size,
       pg_database_size(datname) AS bytes
     FROM pg_database 
     WHERE datistemplate = false
     ORDER BY pg_database_size(datname) DESC;"
}

cmd_ts_size()
{
  q "SELECT spcname AS tablespace, 
       pg_size_pretty(pg_tablespace_size(spcname)) AS size
     FROM pg_tablespace 
     ORDER BY pg_tablespace_size(spcname) DESC;"
}

cmd_schema_size()
{
  q "SELECT nspname AS schema, count(*) AS tables,
       pg_size_pretty(sum(pg_total_relation_size(c.oid))) AS total_size
     FROM pg_class c
     JOIN pg_namespace n ON c.relnamespace = n.oid
     WHERE c.relkind = 'r' AND n.nspname NOT IN ('pg_catalog', 'information_schema')
     GROUP BY nspname 
     ORDER BY sum(pg_total_relation_size(c.oid)) DESC;"
}

# ============================================
# CONFIGURATION
# ============================================

cmd_config()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT name, setting, unit, source, context
     FROM pg_settings 
     WHERE name LIKE '%$sanitized%'
     ORDER BY name;"
}

cmd_config_diff()
{
  q "SELECT name, setting, boot_val AS default, source
     FROM pg_settings 
     WHERE setting IS DISTINCT FROM boot_val
       AND name NOT LIKE '%.%'
     ORDER BY name;"
}

cmd_reload()
{
  q "SELECT pg_reload_conf() AS reloaded;"
}

# ============================================
# SCHEMA INFO
# ============================================

cmd_tables()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, tablename, tableowner,
       pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) AS size
     FROM pg_tables 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND tablename LIKE '%$sanitized%'
     ORDER BY schemaname, tablename;"
}

cmd_indexes()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, tablename, indexname, indexdef
     FROM pg_indexes 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND indexname LIKE '%$sanitized%'
     ORDER BY schemaname, tablename;"
}

cmd_views()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, viewname, viewowner
     FROM pg_views 
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND viewname LIKE '%$sanitized%'
     ORDER BY schemaname, viewname;"
}

cmd_functions()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT n.nspname AS schema, p.proname AS name,
       pg_get_function_arguments(p.oid) AS args,
       pg_get_function_result(p.oid) AS returns,
       p.prokind AS type
     FROM pg_proc p
     JOIN pg_namespace n ON p.pronamespace = n.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
       AND p.proname LIKE '%$sanitized%'
     ORDER BY n.nspname, p.proname;"
}

cmd_triggers()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT event_object_schema AS schema, event_object_table AS table,
       trigger_name, action_timing, event_manipulation AS event
     FROM information_schema.triggers 
     WHERE event_object_schema NOT IN ('pg_catalog', 'information_schema')
       AND trigger_name LIKE '%$sanitized%'
     ORDER BY schema, table;"
}

cmd_fks()
{
  q "SELECT n.nspname AS schema, t.relname AS table,
       c.conname AS constraint,
       array_agg(a.attname ORDER BY array_position(c.conkey, a.attnum)) AS columns,
       fn.nspname AS ref_schema, ft.relname AS ref_table
     FROM pg_constraint c
     JOIN pg_class t ON c.conrelid = t.oid
     JOIN pg_namespace n ON t.relnamespace = n.oid
     JOIN pg_attribute a ON a.attrelid = t.oid AND a.attnum = ANY(c.conkey)
     LEFT JOIN pg_class ft ON c.confrelid = ft.oid
     LEFT JOIN pg_namespace fn ON ft.relnamespace = fn.oid
     WHERE c.contype = 'f' AND n.nspname NOT IN ('pg_catalog', 'information_schema')
     GROUP BY n.nspname, t.relname, c.conname, fn.nspname, ft.relname
     ORDER BY schema, table;"
}

cmd_pks()
{
  q "SELECT n.nspname AS schema, t.relname AS table,
       c.conname AS constraint,
       array_agg(a.attname ORDER BY array_position(c.conkey, a.attnum)) AS columns
     FROM pg_constraint c
     JOIN pg_class t ON c.conrelid = t.oid
     JOIN pg_namespace n ON t.relnamespace = n.oid
     JOIN pg_attribute a ON a.attrelid = t.oid AND a.attnum = ANY(c.conkey)
     WHERE c.contype = 'p' AND n.nspname NOT IN ('pg_catalog', 'information_schema')
     GROUP BY n.nspname, t.relname, c.conname
     ORDER BY schema, table;"
}

cmd_constraints()
{
  q "SELECT n.nspname AS schema, t.relname AS table,
       c.conname AS name,
       CASE c.contype 
         WHEN 'p' THEN 'PRIMARY KEY'
         WHEN 'f' THEN 'FOREIGN KEY'
         WHEN 'u' THEN 'UNIQUE'
         WHEN 'c' THEN 'CHECK'
         WHEN 'x' THEN 'EXCLUSION'
       END AS type
     FROM pg_constraint c
     JOIN pg_class t ON c.conrelid = t.oid
     JOIN pg_namespace n ON t.relnamespace = n.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY schema, table, type;"
}

# ============================================
# SECURITY
# ============================================

cmd_users()
{
  q "SELECT rolname AS username, 
       rolsuper AS superuser, rolcreaterole, rolcreatedb, 
       rolcanlogin AS can_login, rolconnlimit AS conn_limit,
       rolvaliduntil AS valid_until
     FROM pg_roles 
     ORDER BY rolname;"
}

cmd_roles()
{
  q "SELECT rolname, rolsuper, rolinherit, rolcreaterole, 
       rolcreatedb, rolcanlogin, rolreplication, rolbypassrls
     FROM pg_roles 
     ORDER BY rolname;"
}

cmd_permissions()
{
  q "SELECT grantee, table_schema, table_name, 
       string_agg(privilege_type, ', ' ORDER BY privilege_type) AS privileges
     FROM information_schema.role_table_grants 
     WHERE table_schema NOT IN ('pg_catalog', 'information_schema')
     GROUP BY grantee, table_schema, table_name
     ORDER BY grantee, table_schema, table_name;"
}

# ============================================
# HEALTH CHECK
# ============================================

cmd_health()
{
  colorize blue "=== PostgreSQL Health Check ==="
  echo ""
  
  q "SELECT 'Version' AS check, version() AS status;"
  q "SELECT 'Database' AS check, current_database() AS status;"
  q "SELECT 'Uptime' AS check, pg_size_pretty(pg_wal_lsn_diff(pg_current_wal_lsn(), '0/0')) || ' WAL written' AS status;"
  echo ""
  
  q "SELECT 'Connections' AS check, 
       count(*) || ' total, ' || 
       count(*) FILTER(WHERE state='active') || ' active, ' ||
       count(*) FILTER(WHERE state='idle in transaction') || ' idle_tx'
     AS status FROM pg_stat_activity;"
  q "SELECT 'Cache Hit' AS check, 
       round(100.0 * blks_hit / nullif(blks_hit + blks_read, 0), 2) || '%' AS status
     FROM pg_stat_database WHERE datname = current_database();"
  q "SELECT 'Dead Tuples' AS check, 
       sum(n_dead_tup) || ' across ' || count(*) || ' tables' AS status
     FROM pg_stat_user_tables;"
  q "SELECT 'Unused Indexes' AS check, count(*) || ' indexes' AS status
     FROM pg_stat_user_indexes WHERE idx_scan = 0;"
  q "SELECT 'Blocking' AS check, 
       count(*) FILTER(WHERE array_length(pg_blocking_pids(pid),1) > 0) || ' sessions' AS status
     FROM pg_stat_activity;"
}

cmd_overview()
{
  q "SELECT 'PostgreSQL ' || split_part(version(), ' ', 2) AS version;"
  q "SELECT pg_postmaster_start_time() AS started, 
       now() - pg_postmaster_start_time() AS uptime;"
  q "SELECT datname, pg_size_pretty(pg_database_size(datname)) AS size
     FROM pg_database WHERE datistemplate = false
     ORDER BY pg_database_size(datname) DESC;"
}

cmd_uptime()
{
  q "SELECT pg_postmaster_start_time() AS start_time,
       now() - pg_postmaster_start_time() AS uptime,
       date_trunc('second', now() - pg_postmaster_start_time()) AS uptime_formatted;"
}

# ============================================
# UTILITY
# ============================================

cmd_version()
{
  colorize green "Tool: $TOOL_VERSION ($TOOL_BUILD_DATE)"
  q "SELECT version();"
}

cmd_ext()
{
  q "SELECT extname AS name, extversion AS version, n.nspname AS schema
     FROM pg_extension e
     JOIN pg_namespace n ON e.extnamespace = n.oid
     ORDER BY extname;"
}

cmd_set_config()
{
  local name=$1 value=$2
  [ -z "$name" ] || [ -z "$value" ] && { echo "Usage: $EXEC_NAME set_config <name> <value>"; return 1; }
  q "SET $name = '$value'; SELECT current_setting('$name') AS new_value;"
}

cmd_watch()
{
  local secs=$1; shift
  [ -z "$secs" ] && { echo "Usage: $EXEC_NAME watch <seconds> <command>"; return 1; }
  [[ ! "$secs" =~ ^[0-9]+$ ]] && { echo "Error: seconds must be numeric"; return 1; }
  [ $# -eq 0 ] && { echo "Error: no command specified"; return 1; }
  
  while true; do
    clear
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Refresh every ${secs}s"
    echo "========================================"
    dispatch_command "$@"
    sleep "$secs"
  done
}

# ============================================
# ADDITIONAL USEFUL COMMANDS
# ============================================

cmd_explain()
{
  local sql="$*"
  [ -z "$sql" ] && { echo "Usage: $EXEC_NAME explain \"<SQL>\""; return 1; }
  q "EXPLAIN (ANALYZE, BUFFERS, FORMAT TEXT) $sql;"
}

cmd_explain_json()
{
  local sql="$*"
  [ -z "$sql" ] && { echo "Usage: $EXEC_NAME explain_json \"<SQL>\""; return 1; }
  q "EXPLAIN (ANALYZE, BUFFERS, FORMAT JSON) $sql;"
}

cmd_lock_tree()
{
  q "WITH RECURSIVE lock_tree AS (
     SELECT blocked.pid AS blocked_pid, blocked.usename AS blocked_user,
            blocking.pid AS blocking_pid, blocking.usename AS blocking_user,
            1 AS depth, blocked.query AS blocked_query
     FROM pg_stat_activity blocked
     JOIN pg_stat_activity blocking 
       ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
     WHERE blocked.state = 'active'
     )
     SELECT * FROM lock_tree ORDER BY depth, blocked_pid;"
}

cmd_activity()
{
  q "SELECT pid, datname, usename, application_name, 
       client_addr, backend_start, state, 
       wait_event_type, wait_event
     FROM pg_stat_activity 
     WHERE state IS NOT NULL
     ORDER BY backend_start;"
}

cmd_statements_reset()
{
  q "SELECT pg_stat_statements_reset();"
  echo "pg_stat_statements reset complete."
}

cmd_table_stats()
{
  local table=$1
  [ -z "$table" ] && { echo "Usage: $EXEC_NAME table_stats <table>"; return 1; }
  q "SELECT n_live_tup, n_dead_tup, 
       last_vacuum, last_autovacuum, last_analyze, last_autoanalyze,
       vacuum_count, autovacuum_count
     FROM pg_stat_user_tables 
     WHERE relname = '$table';"
}

cmd_seq_scans()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS table, seq_scan, idx_scan,
       n_live_tup, 
       CASE WHEN idx_scan = 0 THEN 'NO INDEX' 
            WHEN seq_scan > idx_scan * 10 THEN 'HIGH SEQ SCAN' 
            ELSE 'OK' END AS status
     FROM pg_stat_user_tables 
     WHERE n_live_tup > 1000
     ORDER BY seq_scan DESC 
     LIMIT $limit;"
}

cmd_bgwriter()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 17 ]; then
    q "SELECT 'checkpointer' AS source, num_timed AS timed, num_requested AS requested,
         write_time, sync_time, buffers_written
       FROM pg_stat_checkpointer
       UNION ALL
       SELECT 'bgwriter', 0, 0, 0, 0, buffers_clean 
       FROM pg_stat_bgwriter;"
  else
    q "SELECT checkpoints_timed AS timed, checkpoints_req AS requested,
         checkpoint_write_time, checkpoint_sync_time,
         buffers_checkpoint, buffers_clean, buffers_backend
       FROM pg_stat_bgwriter;"
  fi
}

# ============================================
# MAIN DISPATCHER
# ============================================

dispatch_command()
{
  local cmd="$1"
  shift

  case "$cmd" in
    ps|sessions)           cmd_ps "$@" ;;
    running)               cmd_running "$@" ;;
    blocking|blocked)      cmd_blocking "$@" ;;
    locks)                 cmd_locks "$@" ;;
    kill)                  cmd_kill "$@" ;;
    cancel)                cmd_cancel "$@" ;;
    sql|fulltext)          cmd_sql "$@" ;;
    
    slow|slow_queries)     cmd_slow "$@" ;;
    top_time|top_queries)  cmd_top_time "$@" ;;
    top_calls)             cmd_top_calls "$@" ;;
    top_io)                cmd_top_io "$@" ;;
    query_history)         cmd_query_history "$@" ;;
    
    table_size|tables_size) cmd_table_size "$@" ;;
    index_size)            cmd_index_size "$@" ;;
    bloat|dead_tuples)     cmd_bloat "$@" ;;
    unused_indexes)        cmd_unused_indexes "$@" ;;
    duplicate_indexes)     cmd_duplicate_indexes "$@" ;;
    missing_indexes)       cmd_missing_indexes "$@" ;;
    
    vacuum_status)         cmd_vacuum_status "$@" ;;
    vacuum_progress)       cmd_vacuum_progress "$@" ;;
    
    conn|connections)      cmd_conn "$@" ;;
    conn_limit)            cmd_conn_limit "$@" ;;
    idle_tx|idle_in_tx)    cmd_idle_tx "$@" ;;
    
    cache_hit)             cmd_cache_hit "$@" ;;
    io_stats)              cmd_io_stats "$@" ;;
    wait_events)           cmd_wait_events "$@" ;;
    temp_files)            cmd_temp_files "$@" ;;
    
    repl|replication)      cmd_repl "$@" ;;
    repl_lag|replication_lag) cmd_repl_lag "$@" ;;
    slot|slots)            cmd_slot "$@" ;;
    
    wal|wal_info)          cmd_wal "$@" ;;
    checkpoint)            cmd_checkpoint "$@" ;;
    
    db_size|database_size) cmd_db_size "$@" ;;
    ts_size|tablespace_size) cmd_ts_size "$@" ;;
    schema_size)           cmd_schema_size "$@" ;;
    
    config)                cmd_config "$@" ;;
    config_diff)           cmd_config_diff "$@" ;;
    reload|reload_config)  cmd_reload "$@" ;;
    
    tables)                cmd_tables "$@" ;;
    indexes)               cmd_indexes "$@" ;;
    views)                 cmd_views "$@" ;;
    functions)             cmd_functions "$@" ;;
    triggers)              cmd_triggers "$@" ;;
    fks|foreign_keys)      cmd_fks "$@" ;;
    pks|primary_keys)      cmd_pks "$@" ;;
    constraints)           cmd_constraints "$@" ;;
    
    users)                 cmd_users "$@" ;;
    roles)                 cmd_roles "$@" ;;
    permissions|privs)     cmd_permissions "$@" ;;
    
    health|health_check)   cmd_health "$@" ;;
    overview)              cmd_overview "$@" ;;
    uptime)                cmd_uptime "$@" ;;
    
    version)               cmd_version "$@" ;;
    ext|extensions)        cmd_ext "$@" ;;
    set_config)            cmd_set_config "$@" ;;
    watch|repeat)          cmd_watch "$@" ;;
    
    explain)               cmd_explain "$@" ;;
    explain_json)          cmd_explain_json "$@" ;;
    lock_tree)             cmd_lock_tree "$@" ;;
    activity)              cmd_activity "$@" ;;
    statements_reset)      cmd_statements_reset "$@" ;;
    table_stats)           cmd_table_stats "$@" ;;
    seq_scans)             cmd_seq_scans "$@" ;;
    bgwriter)              cmd_bgwriter "$@" ;;
    
    *)
      echo "Unknown command: $cmd"
      echo ""
      usage
      ;;
  esac
}

dispatch_command "$COMMAND" "$@"
exit 0