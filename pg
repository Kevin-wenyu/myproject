     FROM pg_stat_user_tables
     WHERE relname = '$sanitized_table';"
}

cmd_seq_scans()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS table_name, seq_scan, idx_scan,
       n_live_tup,
       CASE
         WHEN idx_scan = 0 THEN 'NO INDEX'
         WHEN seq_scan > idx_scan * 10 THEN 'HIGH SEQ SCAN'
         ELSE 'OK'
       END AS status
     FROM pg_stat_user_tables
     WHERE n_live_tup > 5000
     ORDER BY seq_scan DESC
     LIMIT $limit;"
}

