# SLA Tracker
cmd_sla_tracker()
{
  local timeframe="${1:-1h}"

  colorize blue "=== SLA TRACKING REPORT ($timeframe) ==="
  echo ""

  q "WITH sla_metrics AS (
       SELECT
         -- Availability calculation
         'Availability' as metric_name,
         round(
           100.0 - (count(*) FILTER (WHERE state = 'idle' AND now() - backend_start > interval '5min') * 100.0 / count(*)),
           2
         ) as value,
         '99.9%' as target,
         CASE
           WHEN round(100.0 - (count(*) FILTER (WHERE state = 'idle' AND now() - backend_start > interval '5min') * 100.0 / count(*)), 2) >= 99.9
           THEN 'OK' ELSE 'VIOLATED'
         END as status
       FROM pg_stat_activity
       WHERE backend_start > now() - interval '$timeframe'

       UNION ALL

       SELECT
         'Response Time' as metric_name,
         round(avg(extract(epoch from (now() - query_start))), 2) as value,
         '0.5' as target,
         CASE
           WHEN round(avg(extract(epoch from (now() - query_start))), 2) <= 0.5
           THEN 'OK' ELSE 'VIOLATED'
         END as status
       FROM pg_stat_activity
       WHERE state = 'active' AND query_start > now() - interval '$timeframe'

       UNION ALL

       SELECT
         'Throughput' as metric_name,
         count(*) as value,
         '1000' as target,
         CASE
           WHEN count(*) >= 1000 THEN 'OK' ELSE 'VIOLATED'
         END as status
       FROM pg_stat_activity
       WHERE query_start > now() - interval '1 minute'
     )
     SELECT metric_name, value, target, status
     FROM sla_metrics;"
}

# Intelligent Alert Engine
cmd_alert_engine()
{
  colorize blue "=== INTELLIGENT ALERT ENGINE ==="
  echo ""

  # Check various enterprise-level alerts
  local issues=0

  # Check connection count
  local conn_limit_output
  conn_limit_output=$(cmd_conn_limit 2>&1)
  local current_conns=$(echo "$conn_limit_output" | grep "current_connections" | awk '{print $2}')
  local max_conns=$(echo "$conn_limit_output" | grep "max_connections" | awk '{print $2}')

  # Verify that we have valid numeric values before arithmetic operations
  if [[ "$current_conns" =~ ^[0-9]+$ ]] && [[ "$max_conns" =~ ^[0-9]+$ ]] && [ "$max_conns" -gt 0 ]; then
    local usage_percent=$((current_conns * 100 / max_conns))

    if [ "$usage_percent" -gt 90 ]; then
      colorize red "CRITICAL: Connection usage at ${usage_percent}% (>$((max_conns * 90 / 100)) connections)"
      issues=$((issues+1))
    elif [ "$usage_percent" -gt 80 ]; then
      colorize yellow "WARNING: Connection usage at ${usage_percent}% (>$((max_conns * 80 / 100)) connections)"
      issues=$((issues+1))
    fi
  else
    colorize yellow "WARNING: Unable to determine connection usage (invalid data received)"
    issues=$((issues+1))
  fi

  # Check blocking sessions
  local blocking_count
  blocking_count=$(cmd_blocking 2>&1 | wc -l)
  if [[ "$blocking_count" =~ ^[0-9]+$ ]]; then
    if [ "$blocking_count" -gt 5 ]; then
      colorize red "CRITICAL: $((blocking_count-3)) blocking sessions detected"
      issues=$((issues+1))
    elif [ "$blocking_count" -gt 2 ]; then
      colorize yellow "WARNING: $((blocking_count-3)) blocking sessions detected"
      issues=$((issues+1))
    fi
  else
    colorize yellow "WARNING: Unable to determine blocking session count (invalid data received)"
    issues=$((issues+1))
  fi

  # Check slow queries if pg_stat_statements is available
  if [ -n "$(extension_installed pg_stat_statements)" ]; then
    local slow_query_count
    slow_query_count=$(run_stat_statements "SELECT count(*) FROM pg_stat_statements WHERE mean_time > 1000;" 2>/dev/null | head -1)
    if [ -n "$slow_query_count" ] && [[ "$slow_query_count" =~ ^[0-9]+$ ]]; then
      if [ "$slow_query_count" -gt 10 ]; then
        colorize red "CRITICAL: $slow_query_count queries with mean time > 1000ms"
        issues=$((issues+1))
      elif [ "$slow_query_count" -gt 5 ]; then
        colorize yellow "WARNING: $slow_query_count queries with mean time > 1000ms"
        issues=$((issues+1))
      fi
    fi
  fi

  # Check table bloat
  local bloat_issues
  bloat_issues=$(cmd_bloat 10 2>/dev/null | tail -n +2 | awk '$4 > 30 { count++ } END { print count+0 }' 2>/dev/null || echo 0)
  if [[ "$bloat_issues" =~ ^[0-9]+$ ]]; then
    if [ "$bloat_issues" -gt 5 ]; then
      colorize yellow "WARNING: $bloat_issues tables with >30% bloat detected"
      issues=$((issues+1))
    fi
  fi

  # Check cache hit ratio
  local cache_hit_line
  cache_hit_line=$(cmd_cache_hit 2>&1 | grep -v "level\|Database" | head -1)
  local cache_ratio=$(echo "$cache_hit_line" | awk '{print $NF}' | sed 's/%//')
  if [[ "$cache_ratio" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(echo "$cache_ratio < 85" | bc -l) )); then
    colorize red "CRITICAL: Low cache hit ratio: ${cache_ratio}%"
    issues=$((issues+1))
  elif [[ "$cache_ratio" =~ ^[0-9]+\.?[0-9]*$ ]] && (( $(echo "$cache_ratio < 95" | bc -l) )); then
    colorize yellow "WARNING: Moderate cache hit ratio: ${cache_ratio}%"
    issues=$((issues+1))
  fi

  if [ "$issues" -eq 0 ]; then
    colorize green "No critical issues detected - System healthy"
  fi
}

