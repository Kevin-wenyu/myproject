while [[ $# -gt 0 ]]; do
  case $1 in
    -h|--host)     DBHOST="$2"; shift 2 ;;
    -p|--port)     DBPORT="$2"; shift 2 ;;
    -u|--user)     DBUSER="$2"; shift 2 ;;
    -d|--dbname)   DBNAME="$2"; shift 2 ;;
    -P|--password-file) USE_PASSWORD_FILE="$2"; shift 2 ;;
    -n|--top)      TOP_N="$2"; shift 2 ;;
    --help)        usage ;;
    *)             break ;;
  esac
done

if [ -n "$PGPASSWORD" ] || [ -n "$PGPASSFILE" ] || [ -n "$USE_PASSWORD_FILE" ]; then
  PSQL_CMD="psql -h $DBHOST -p $DBPORT -U $DBUSER -d $DBNAME -w"
else
  PSQL_CMD="psql -h $DBHOST -p $DBPORT -U $DBUSER -d $DBNAME"
fi

get_version

[ $# -lt 1 ] && usage

COMMAND="$1"
shift

q()
{
  local query="$1"
  local result
  local exit_code

  # Validate input - basic check to ensure query is not empty
  if [ -z "$query" ]; then
    echo "Error: Empty query provided" >&2
    return 1
  fi

  # Execute query with timing if DEBUG_QUERIES is set
  if [ "${DEBUG_QUERIES:-0}" = "1" ]; then
    local start_time=$(date +%s.%N)
    result=$(echo "$query" | $PSQL_CMD 2>&1)
    local end_time=$(date +%s.%N)
    local duration=$(echo "$end_time - $start_time" | bc -l)
    echo "# Query took: ${duration}s" >&2
    echo "# Query: $query" >&2
  else
    result=$(echo "$query" | $PSQL_CMD 2>&1)
  fi

  exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo "Error: psql command failed with exit code $exit_code" >&2
    echo "Query: $query" >&2
    echo "Details: $result" >&2
    return $exit_code
  fi
  echo "$result"
}

q_sanitize()
{
  local input="$1"
  # First, remove any null bytes which could be used in some injection attacks
  input=$(printf '%s' "$input" | tr -d '\000')

  # Remove any potentially dangerous characters
  # Allow only alphanumeric characters, underscore, space, dot, dash, colon, and percent signs (for LIKE patterns)
  local sanitized=$(printf '%s' "$input" | sed 's/[^a-zA-Z0-9_ .:%-]/_/g')

  # Escape single quotes by doubling them (PostgreSQL's SQL string escape mechanism)
  sanitized=$(printf '%s' "$sanitized" | sed "s/'/''/g")

  # Additional protection: ensure the input doesn't contain SQL keywords or dangerous patterns
  # Convert to lowercase for comparison but preserve original case in output
  local lower_input=$(printf '%s' "$sanitized" | tr '[:upper:]' '[:lower:]')

  # Check for potentially dangerous patterns
  if [[ "$lower_input" =~ (drop|truncate|delete|insert|update|exec|execute|alter|create|merge|replace|grant|revoke|commit|rollback|begin|transaction|union|select\b.*\bfrom|order\s+by|group\s+by|having|limit|offset|join|into|values|where) ]]; then
    # If dangerous patterns are detected, strip them out
    sanitized=$(printf '%s' "$sanitized" | sed 's/[;,]//g')  # Remove potential statement terminators
    sanitized=$(printf '%s' "$sanitized" | sed 's/[-]{2,}//g')  # Remove comment indicators
    sanitized=$(printf '%s' "$sanitized" | sed 's/[\/][*].*[*][/][ \t\n\r\f]*/ /g')  # Remove /* */ style comments
  fi

  echo "$sanitized"
}

# ============================================
# QUICK DIAGNOSTICS
# ============================================

cmd_ps()
{
  local limit=${1:-50}
  q "SELECT pid, usename, application_name, client_addr::text, state, 
       now()-query_start AS duration,
       wait_event_type, wait_event, LEFT(query, 80) AS query
     FROM pg_stat_activity 
     WHERE state = 'active'
     ORDER BY query_start DESC 
     LIMIT $limit;"
}

cmd_running()
{
  local limit=${1:-$TOP_N}
  q "SELECT pid, usename, application_name, 
       now()-query_start AS duration, 
       wait_event_type, wait_event,
       LEFT(query, 120) AS query
     FROM pg_stat_activity 
     WHERE state = 'active' AND query NOT LIKE '%pg_stat_activity%'
     ORDER BY query_start LIMIT $limit;"
}

cmd_blocking()
{
  q "SELECT blocked.pid AS blocked_pid, blocked.usename AS blocked_user,
       blocking.pid AS blocking_pid, blocking.usename AS blocking_user,
       blocked.wait_event, 
       now() - blocked.query_start AS duration,
       LEFT(blocked.query, 80) AS blocked_query
     FROM pg_stat_activity blocked
     JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
     WHERE blocked.state = 'active';"
}

cmd_locks()
{
  q "SELECT l.locktype, l.mode, l.granted, a.pid, a.usename,
       COALESCE(c.relname, '') AS relation,
       LEFT(a.query, 60) AS query
     FROM pg_locks l
     JOIN pg_stat_activity a ON l.pid = a.pid
     LEFT JOIN pg_class c ON l.relation = c.oid
     WHERE l.relation IS NOT NULL OR l.locktype IN ('transactionid', 'virtualxid')
     ORDER BY l.granted, a.pid;"
}

cmd_kill()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME kill <pid>"; return 1; }
  [[ ! "$pid" =~ ^[0-9]+$ ]] && { echo "Error: PID must be numeric"; return 1; }

  local result
  result=$(q "SELECT pg_terminate_backend($pid::integer) AS result;")
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    echo "Error: Failed to terminate backend process $pid" >&2
    return $exit_code
  fi

  echo "$result"
}

cmd_cancel()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME cancel <pid>"; return 1; }
  [[ ! "$pid" =~ ^[0-9]+$ ]] && { echo "Error: PID must be numeric"; return 1; }

  local result
  result=$(q "SELECT pg_cancel_backend($pid::integer) AS result;")
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    echo "Error: Failed to cancel query for process $pid" >&2
    return $exit_code
  fi

  echo "$result"
}

cmd_sql()
{
  local pid=$1
  [ -z "$pid" ] && { echo "Usage: $EXEC_NAME sql <pid>"; return 1; }

  # Validate PID is numeric to prevent SQL injection
  if ! [[ "$pid" =~ ^[0-9]+$ ]]; then
    echo "Error: PID must be numeric" >&2
    return 1
  fi

  q "SELECT pid, usename, state, now()-query_start AS duration, query FROM pg_stat_activity WHERE pid = $pid;"
}

# ============================================
# SLOW QUERY ANALYSIS
# ============================================

cmd_slow()
{
  local secs=${1:-5}
  # Validate input is numeric and reasonable
  if ! [[ "$secs" =~ ^[0-9]+$ ]]; then
    echo "Error: seconds must be a positive integer" >&2
    return 1
  fi
  if [ "$secs" -gt 86400 ]; then
    echo "Error: maximum 24 hours (86400 seconds)" >&2
    return 1
  fi
  q "SELECT pid, usename, application_name, client_addr::text,
       now()-query_start AS duration, state, wait_event,
       query
     FROM pg_stat_activity 
     WHERE state = 'active' 
       AND now()-query_start > interval '$secs seconds'
       AND query NOT LIKE '%pg_stat_activity%'
     ORDER BY query_start;"
}

cmd_top_time()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT LEFT(query, 100) AS query, calls,
       ROUND(${PGS_TOTAL_COL}/1000.0, 2) AS total_sec,
       ROUND(${PGS_MEAN_COL}/1000.0, 4) AS mean_sec,
       rows
     FROM pg_stat_statements
     ORDER BY ${PGS_TOTAL_COL} DESC LIMIT $limit;"
}

cmd_top_calls()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT LEFT(query, 100) AS query, calls,
       ROUND(${PGS_TOTAL_COL}/1000.0, 2) AS total_sec,
       ROUND(${PGS_MEAN_COL}/1000.0, 4) AS mean_sec,
       rows
     FROM pg_stat_statements
     ORDER BY calls DESC LIMIT $limit;"
}

cmd_top_io()
{
  local limit=${1:-$TOP_N}
  run_stat_statements "SELECT LEFT(query, 80) AS query, calls,
       shared_blks_read, shared_blks_hit,
       temp_blks_read, temp_blks_written
     FROM pg_stat_statements 
     WHERE shared_blks_read > 0 OR temp_blks_read > 0
     ORDER BY shared_blks_read + temp_blks_read DESC 
     LIMIT $limit;"
}

cmd_query_history()
{
  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns
  run_stat_statements "SELECT queryid, LEFT(query, 80) AS query, calls,
       ROUND(${PGS_MEAN_COL}::numeric, 2) AS mean_ms,
       ROUND(${PGS_MAX_COL}::numeric, 2) AS max_ms,
       rows,
       shared_blks_hit + shared_blks_read AS blks
     FROM pg_stat_statements
     ORDER BY calls DESC LIMIT $limit;"
}

# ============================================
# TABLE & INDEX
# ============================================

cmd_table_size()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, tablename,
       pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) AS total_size,
       pg_size_pretty(pg_relation_size(schemaname||'.'||tablename)) AS table_size,
       pg_size_pretty(pg_indexes_size(schemaname||'.'||tablename)) AS index_size
     FROM pg_tables
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND tablename LIKE '%$sanitized%'
     ORDER BY pg_total_relation_size(schemaname||'.'||tablename) DESC
     LIMIT $TOP_N;"
}

cmd_index_size()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT schemaname, relname AS tablename, indexrelname AS indexname,
       pg_size_pretty(pg_relation_size(indexrelid)) AS size,
       idx_scan, idx_tup_read
     FROM pg_stat_user_indexes
     WHERE schemaname NOT IN ('pg_catalog', 'information_schema')
       AND indexrelname LIKE '%$sanitized%'
     ORDER BY pg_relation_size(indexrelid) DESC
     LIMIT $TOP_N;"
}

cmd_bloat()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS tablename,
       n_live_tup, n_dead_tup,
       CASE WHEN n_live_tup + n_dead_tup > 0
         THEN ROUND(100.0 * n_dead_tup / (n_live_tup + n_dead_tup), 2)
         ELSE 0 END AS dead_pct,
       CASE WHEN n_live_tup > 0
         THEN ROUND(n_dead_tup::numeric / n_live_tup, 4)
         ELSE 0 END AS dead_ratio,
       last_vacuum, last_autovacuum,
       CASE
         WHEN n_dead_tup > 10000 AND last_vacuum < now() - interval '1 hour' THEN 'ACTION needed'
         WHEN n_dead_tup > 5000 AND last_vacuum < now() - interval '30 minutes' THEN 'monitor'
         ELSE 'OK'
       END AS status
     FROM pg_stat_user_tables
     WHERE n_dead_tup > 0
     ORDER BY n_dead_tup DESC
     LIMIT $limit;"
}

cmd_unused_indexes()
{
  q "SELECT s.schemaname, s.relname AS tablename, s.indexrelname AS indexname,
       pg_size_pretty(pg_relation_size(s.indexrelid)) AS size,
       s.idx_scan, s.idx_tup_read, s.idx_tup_fetch
     FROM pg_stat_user_indexes s
     JOIN pg_index i ON s.indexrelid = i.indexrelid
     WHERE s.idx_scan = 0
       AND NOT i.indisprimary
       AND NOT i.indisunique
       AND NOT i.indisclustered
       AND s.schemaname NOT IN ('pg_catalog', 'information_schema')
       AND pg_relation_size(s.indexrelid) > 1024
     ORDER BY pg_relation_size(s.indexrelid) DESC;"
}

cmd_duplicate_indexes()
{
  q "SELECT i1.schemaname AS schema, t.relname AS table_name,
       i1.relname AS index1, i2.relname AS index2,
       pg_size_pretty(pg_relation_size(i2.schemaname||'.'||i2.relname)) AS wasted_size
     FROM pg_index idx1
     JOIN pg_index idx2 ON idx1.indrelid = idx2.indrelid
       AND idx1.indexrelid < idx2.indexrelid
       AND idx1.indkey = idx2.indkey
     JOIN pg_class t ON t.oid = idx1.indrelid
     JOIN pg_class i1 ON i1.oid = idx1.indexrelid
     JOIN pg_class i2 ON i2.oid = idx2.indexrelid
     JOIN pg_namespace n ON n.oid = t.relnamespace
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
       AND pg_relation_size(i2.schemaname||'.'||i2.relname) > 1024
     ORDER BY t.relname;"
}

cmd_missing_indexes()
{
  q "SELECT schemaname, relname AS tablename,
       seq_scan, idx_scan, n_live_tup,
       CASE 
         WHEN n_live_tup > 10000 AND seq_scan > 100 AND idx_scan = 0 THEN 'CRITICAL'
         WHEN n_live_tup > 10000 AND seq_scan > 100 AND idx_scan > 0 THEN 'HIGH'
         WHEN n_live_tup > 5000 AND seq_scan > 50 THEN 'MEDIUM'
         WHEN seq_scan > 100 THEN 'LOW'
         ELSE 'OK'
       END AS need_index
     FROM pg_stat_user_tables 
     WHERE n_live_tup > 1000 AND seq_scan > 10
     ORDER BY seq_scan DESC 
     LIMIT $TOP_N;"
}

