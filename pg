            array_agg(blocked_pid) AS blocked_pids,
            array_agg(blocked_user) AS blocked_users,
            max(waiting_duration) AS max_wait_time,
            wait_event_type, wait_event
       FROM lock_waiters
       GROUP BY blocking_pid, blocking_user, blocking_query, 
                wait_event_type, wait_event
       ORDER BY max_wait_time DESC;"
}

cmd_index_usage_pattern()
{
  local limit=${1:-50}
  q "SELECT s.schemaname,
       s.relname AS table_name,
       s.indexrelname AS index,
       s.idx_scan,
       s.idx_tup_read,
       s.idx_tup_fetch,
       pg_size_pretty(pg_relation_size(s.indexrelid)) AS size
     FROM pg_stat_user_indexes s
     JOIN pg_index i ON s.indexrelid = i.indexrelid
     WHERE s.indisvalid
       AND s.schemaname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY s.idx_scan DESC, s.idx_tup_read DESC
     LIMIT $limit;"
}

cmd_bloat_analysis()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS table_name,
       n_live_tup, n_dead_tup,
       CASE WHEN n_live_tup + n_dead_tup > 0
         THEN round(100.0 * n_dead_tup / (n_live_tup + n_dead_tup), 2)
         ELSE 0 END AS dead_pct,
       pg_size_pretty(pg_relation_size(schemaname||'.'||relname)) AS table_size,
       pg_size_pretty(pg_total_relation_size(schemaname||'.'||relname)) AS total_size,
       CASE
         WHEN n_dead_tup > 10000 AND last_vacuum < now() - interval '1 hour' THEN 'ACTION needed'
         WHEN n_dead_tup > 5000 AND last_vacuum < now() - interval '30 minutes' THEN 'monitor'
         ELSE 'OK'
       END AS status
     FROM pg_stat_user_tables
     WHERE n_dead_tup > 0
     ORDER BY n_dead_tup DESC
     LIMIT $limit;"
}

cmd_toast_tables()
{
  q "SELECT n.nspname AS schema,
       parent.relname AS table_name,
       t.relname AS toast_table,
       pg_size_pretty(pg_relation_size(t.schemaname||'.'||t.relname)) AS toast_size,
       pg_size_pretty(pg_total_relation_size(parent.schemaname||'.'||parent.relname)) AS total_table_size
     FROM pg_class parent
     JOIN pg_namespace n ON parent.relnamespace = n.oid
     JOIN pg_class t ON parent.reltoastrelid = t.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
       AND pg_relation_size(t.schemaname||'.'||t.relname) > 1048576
     ORDER BY pg_relation_size(t.schemaname||'.'||t.relname) DESC;"
}

cmd_partition_info()
{
  local pattern="${1:-%}"
  local sanitized=$(q_sanitize "$pattern")
  q "SELECT n.nspname AS schema,
       parent.relname AS parent_table,
       child.relname AS partition,
       pg_get_expr(child.relpartbound, child.oid) AS partition_bound,
       pg_size_pretty(pg_relation_size(child.schemaname||'.'||child.relname)) AS size,
       child.relkind AS type
     FROM pg_inherits i
     JOIN pg_class parent ON i.inhparent = parent.oid
     JOIN pg_class child ON i.inhrelid = child.oid
     JOIN pg_namespace n ON parent.relnamespace = n.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
       AND parent.relname LIKE '%$sanitized%'
     ORDER BY parent.relname, child.relname;"
}

cmd_partition_summary()
{
  q "SELECT n.nspname AS schema,
       parent.relname AS parent_table,
       count(*) AS num_partitions,
       pg_size_pretty(sum(pg_relation_size(child.schemaname||'.'||child.relname))) AS total_partition_size
     FROM pg_inherits i
     JOIN pg_class parent ON i.inhparent = parent.oid
     JOIN pg_class child ON i.inhrelid = child.oid
     JOIN pg_namespace n ON parent.relnamespace = n.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
     GROUP BY n.nspname, parent.relname
     ORDER BY sum(pg_relation_size(child.schemaname||'.'||child.relname)) DESC;"
}


cmd_active_transactions()
{
