readonly TOOL_BUILD_DATE="2026-03-26"

PG_VERSION=""
PG_MAJOR_VERSION=""
PGS_TOTAL_COL=""
PGS_MEAN_COL=""
PGS_MAX_COL=""
# Version compatibility flags
HAS_PG_WAIT_EVENTS=""
WAIT_EVENTS_SOURCE=""
HAS_REPLICATION_SLOTS=""
PG_TERMINATE_FUNC=""
HAS_PG_STAT_CHECKPOUNTS=""
HAS_WAL_METRICS=""
EXEC_NAME=$(basename "$0")
DBHOST="${PGHOST:-localhost}"
DBPORT="${PGPORT:-5432}"
DBUSER="${PGUSER:-postgres}"
DBNAME="${PGDATABASE:-postgres}"
DBPASSWORD="${PGPASSWORD:-}"
TOP_N=10
USE_PASSWORD_FILE=""
DEBUG_QUERIES="${DEBUG_QUERIES:-0}"

setup_password()
{
  if [ -n "$PGPASSWORD" ]; then
    export PGPASSWORD="$PGPASSWORD"
    return 0
  fi

  if [ -n "$USE_PASSWORD_FILE" ] && [ -f "$USE_PASSWORD_FILE" ]; then
    chmod 600 "$USE_PASSWORD_FILE" 2>/dev/null || true
    DBPASSWORD=$(cat "$USE_PASSWORD_FILE")
    export PGPASSWORD="$DBPASSWORD"
    return 0
  fi

  local pgpass_file="$HOME/.pgpass"
  if [ -f "$pgpass_file" ]; then
    chmod 600 "$pgpass_file" 2>/dev/null || true
    export PGPASSFILE="$pgpass_file"
    return 0
  fi

  local local_pgpass="$(pwd)/.pgpass"
  if [ -f "$local_pgpass" ]; then
    chmod 600 "$local_pgpass" 2>/dev/null || true
    export PGPASSFILE="$local_pgpass"
    return 0
  fi
}

setup_password

use_color=true
# Check if output is a terminal and TERM is not dumb, but also respect NO_COLOR environment variable
if [ "$FORCE_COLOR" = "1" ] || [ "$FORCE_COLOR" = "true" ]; then
    use_color=true
elif [ -t 1 ] && [ "$TERM" != "dumb" ] && [ -z "$NO_COLOR" ]; then
    use_color=true
else
    use_color=false
fi

readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

colorize()
{
  local color=$1 text="$2"
  [ "$use_color" = true ] || { echo "$text"; return; }
  case "$color" in
    red)    printf "${RED}%s${NC}\n" "$text" ;;
    green)  printf "${GREEN}%s${NC}\n" "$text" ;;
    yellow) printf "${YELLOW}%s${NC}\n" "$text" ;;
    blue)   printf "${BLUE}%s${NC}\n" "$text" ;;
    *)      echo "$text" ;;
  esac
}

# ============================================
# OUTPUT FORMATTING UTILITIES
# ============================================

# 统一消息前缀
msg_info()  { echo "[INFO] $1"; }
msg_warn()  { colorize yellow "[WARN] $1"; }
msg_error() { colorize red "[ERROR] $1"; }

# 空结果处理
handle_empty() {
  local result="$1"
  local message="${2:-No results found}"
  if [ -z "$result" ] || [ "$result" = " " ] || [ "$result" = "" ]; then
    msg_info "$message"
    return 0
  fi
  echo "$result"
}

# 数值格式化 - 百分比保留1位小数
format_percent() {
  local value="$1"
  if [[ "$value" =~ ^[0-9]+\.?[0-9]*$ ]]; then
    printf "%.1f%%" "$value"
  else
    echo "$value"
  fi
}

# 数值格式化 - 大数字千分位
format_number() {
  local num="$1"
  if [[ "$num" =~ ^[0-9]+$ ]]; then
    printf "%'d" "$num"
  else
    echo "$num"
  fi
}

# 表格分隔线
print_separator() {
  local width="${1:-80}"
  printf "%${width}s\n" | tr ' ' '-'
}

get_version()
{
  local version_output
  version_output=$(psql -h "$DBHOST" -p "$DBPORT" -U "$DBUSER" -d "$DBNAME" -t -A -c "SELECT version();" 2>&1)
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    echo "Error: Could not connect to PostgreSQL" >&2
    echo "Connection details: host=$DBHOST port=$DBPORT user=$DBUSER database=$DBNAME" >&2
    echo "Error details: $version_output" >&2
    exit 1
  fi

  if [ -z "$version_output" ] || [ "$version_output" = " " ]; then
    echo "Error: Empty version response from PostgreSQL" >&2
    exit 1
  fi

  PG_VERSION=$(echo "$version_output" | sed -n 's/^PostgreSQL \([0-9.]*\).*/\1/p' | head -1)
  if [ -z "$PG_VERSION" ]; then
    echo "Error: Could not parse PostgreSQL version from: $version_output" >&2
    exit 1
  fi
  PG_MAJOR_VERSION=$(echo "$PG_VERSION" | cut -d. -f1)
}

init_pg_stat_statements_columns()
{
  [ -n "$PGS_TOTAL_COL" ] && return 0

  local rel_exists
  rel_exists=$(echo "SELECT 1 FROM pg_class WHERE relname = 'pg_stat_statements' AND relkind IN ('v','r');" | $PSQL_CMD -t -A 2>&1)
  if [ $? -ne 0 ] || [ -z "$rel_exists" ]; then
    return 1
  fi

  local has_new
  has_new=$(echo "SELECT 1 FROM pg_attribute WHERE attrelid = 'pg_stat_statements'::regclass AND attname = 'total_exec_time';" | $PSQL_CMD -t -A 2>&1)
  if [ $? -eq 0 ] && [ -n "$has_new" ]; then
    PGS_TOTAL_COL="total_exec_time"
    PGS_MEAN_COL="mean_exec_time"
    PGS_MAX_COL="max_exec_time"
  else
    PGS_TOTAL_COL="total_time"
    PGS_MEAN_COL="mean_time"
    PGS_MAX_COL="max_time"
  fi
  return 0
}

# ============================================
# VERSION COMPATIBILITY
# ============================================

init_version_features() {
  # pg_stat_statements 列名兼容 (PG 13+ 使用 total_exec_time)
  init_pg_stat_statements_columns

  # 等待事件 (PG 10+ 有独立的 pg_stat_wait_events, PG 17+ 有 pg_wait_events)
  if [ "$PG_MAJOR_VERSION" -ge 17 ]; then
    HAS_PG_WAIT_EVENTS=true
    WAIT_EVENTS_SOURCE="pg_wait_events"
  elif [ "$PG_MAJOR_VERSION" -ge 10 ]; then
    HAS_PG_WAIT_EVENTS=false
    WAIT_EVENTS_SOURCE="pg_stat_activity"
  else
    HAS_PG_WAIT_EVENTS=false
    WAIT_EVENTS_SOURCE="pg_stat_activity"
  fi

  # 复制槽 (PG 10+)
  HAS_REPLICATION_SLOTS=$([ "$PG_MAJOR_VERSION" -ge 10 ] && echo true || echo false)

  # 进程管理 (PG 14+ terminate_backend 支持超时参数)
  if [ "$PG_MAJOR_VERSION" -ge 14 ]; then
    PG_TERMINATE_FUNC="pg_terminate_backend(pid, 60)"
  else
    PG_TERMINATE_FUNC="pg_terminate_backend(pid)"
  fi

  # Checkpoint 统计 (PG 17+)
  HAS_PG_STAT_CHECKPOUNTS=$([ "$PG_MAJOR_VERSION" -ge 17 ] && echo true || echo false)

  # WAL 指标 (PG 18+ pg_stat_statements 可能有 wal_fpi 列)
  if [ "$PG_MAJOR_VERSION" -ge 18 ]; then
    # 动态检测新列
    local has_wal_metrics
    has_wal_metrics=$(echo "SELECT 1 FROM pg_attribute WHERE attrelid = 'pg_stat_statements'::regclass AND attname = 'wal_fpi' LIMIT 1;" | $PSQL_CMD -t -A 2>/dev/null || echo "")
    HAS_WAL_METRICS=$([ -n "$has_wal_metrics" ] && echo true || echo false)
  else
    HAS_WAL_METRICS=false
  fi
}

extension_installed()
{
  local ext="$1"
  local result

  # Sanitize extension name to prevent SQL injection
  local sanitized_ext=$(q_sanitize "$ext")

  # Validate extension name format
  if [[ ! "$sanitized_ext" =~ ^[a-zA-Z0-9_]+$ ]]; then
    echo "" >&2
    return 1
  fi

  result=$(echo "SELECT 1 FROM pg_extension WHERE extname = '$sanitized_ext';" | $PSQL_CMD -t -A 2>&1)
  if [ $? -eq 0 ] && [ -n "$result" ] && [ "$result" != " " ]; then
    echo "$result"
  else
    echo ""
  fi
}

# ============================================
# ERROR HANDLING UTILITIES
# ============================================

# 安全执行 - 统一错误处理
safe_execute() {
  local cmd="$1"
  local fallback="${2:-}"

  local result
  result=$(eval "$cmd" 2>&1)
  local exit_code=$?

  if [ $exit_code -ne 0 ]; then
    case "$result" in
      *"permission denied"*)
        msg_error "Permission denied - check role privileges"
        ;;
      *"does not exist"*)
        msg_warn "Required object not found"
        ;;
      *"connection"*|*"connect"*)
        msg_error "Connection failed - check PostgreSQL status and connection parameters"
        ;;
      *"syntax error"*)
        msg_error "SQL syntax error"
        ;;
      *)
        msg_error "$result"
        ;;
    esac
    [ -n "$fallback" ] && eval "$fallback"
    return 1
  fi
  echo "$result"
  return 0
}

# 扩展依赖检查 - 带提示
require_extension() {
  local ext="$1"
  local hint="${2:-Run: CREATE EXTENSION $ext;}"

  if [ -z "$(extension_installed "$ext")" ]; then
    msg_warn "Extension '$ext' not installed. $hint"
    return 1
  fi
  return 0
}

# 权限检查
require_privilege() {
  local privilege="$1"
  local has_priv
  has_priv=$(q "SELECT has_database_privilege(current_database(), '$privilege');" 2>/dev/null)
  if [ "$has_priv" != "t" ]; then
    msg_warn "Missing privilege: $privilege"
    return 1
  fi
  return 0
}

# 超级用户检查
require_superuser() {
  local is_superuser
  is_superuser=$(q "SELECT current_setting('is_superuser');" 2>/dev/null)
  if [ "$is_superuser" != "on" ]; then
    msg_warn "This command requires superuser privileges"
    return 1
  fi
  return 0
}

run_stat_statements()
{
  local query="$1"
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed."
    echo "Run: CREATE EXTENSION pg_stat_statements;"
    return 1
  fi
  init_pg_stat_statements_columns || {
    echo "Error: Could not initialize pg_stat_statements columns."
    return 1
  }
  local result
  result=$(echo "$query" | $PSQL_CMD 2>&1)
  local exit_code=$?
  if [ $exit_code -ne 0 ]; then
    echo "Error: Failed to execute query" >&2
    return $exit_code
  fi
  echo "$result"
}

