cmd_cache_hit()
{
  q "SELECT 'Database' AS level, datname,
       CASE
         WHEN blks_hit + blks_read = 0 THEN NULL
         ELSE ROUND(100.0 * blks_hit / (blks_hit + blks_read), 2)
       END AS hit_ratio
     FROM pg_stat_database
     WHERE datname NOT IN ('template0', 'template1')
     UNION ALL
     SELECT 'Table' AS level, schemaname||'.'||relname,
       CASE
         WHEN heap_blks_hit + heap_blks_read = 0 THEN NULL
         ELSE ROUND(100.0 * heap_blks_hit / (heap_blks_hit + heap_blks_read), 2)
       END
     FROM pg_statio_user_tables
     WHERE heap_blks_read + heap_blks_hit > 0
     ORDER BY hit_ratio ASC
     LIMIT 20;"
}

cmd_io_stats()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 18 ]; then
    q "SELECT source, relname, phase,
         read_bytes, write_bytes, extend_bytes,
