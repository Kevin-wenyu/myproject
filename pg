     FROM pg_settings
     WHERE name = 'log_connections'

     UNION ALL

     SELECT
       'LOCK_WAIT_LOGGING' as check_name,
       CASE WHEN name = 'log_lock_waits' AND setting = 'on' THEN 'PASS' ELSE 'FAIL' END as status,
       'Lock wait logging should be enabled' as recommendation
     FROM pg_settings
     WHERE name = 'log_lock_waits'

     UNION ALL

     SELECT
       'PASSWORD_ENCRYPTION' as check_name,
       CASE WHEN name = 'password_encryption' AND setting IN ('scram-sha-256', 'md5') THEN 'PASS' ELSE 'FAIL' END as status,
       'Strong password encryption should be used' as recommendation
     FROM pg_settings
     WHERE name = 'password_encryption'

     ORDER BY status, check_name;"
