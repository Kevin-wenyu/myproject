cmd_checkpoint()
{
  if [ "${PG_MAJOR_VERSION:-0}" -ge 18 ]; then
    # PostgreSQL 18+ may have additional fields in pg_stat_checkpointer
    q "SELECT 'timed' AS type, num_timed::text AS count FROM pg_stat_checkpointer
       UNION ALL SELECT 'requested', num_requested::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'write_time_ms', write_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'sync_time_ms', sync_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'buffers_written', buffers_written::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'num_done', num_done::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'buf_written_clean', buf_written_clean::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'max_sync_time', max_sync_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'total_buffers_written', total_buffers_written::text FROM pg_stat_checkpointer;"
  elif [ "${PG_MAJOR_VERSION:-0}" -ge 17 ]; then
    # PostgreSQL 17 has different fields than earlier versions
    q "SELECT 'timed' AS type, num_timed::text AS count FROM pg_stat_checkpointer
       UNION ALL SELECT 'requested', num_requested::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'write_time_ms', write_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'sync_time_ms', sync_time::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'buffers_written', buffers_written::text FROM pg_stat_checkpointer
       UNION ALL SELECT 'num_done', num_done::text FROM pg_stat_checkpointer;"
  else
    # Older versions (before 17) use pg_stat_bgwriter
    q "SELECT 'timed' AS type, checkpoints_timed::text AS count FROM pg_stat_bgwriter
       UNION ALL SELECT 'requested', checkpoints_req::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'write_time_ms', checkpoint_write_time::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'sync_time_ms', checkpoint_sync_time::text FROM pg_stat_bgwriter
       UNION ALL SELECT 'buffers_checkpoint', buffers_checkpoint::text FROM pg_stat_bgwriter;"
   fi
}

cmd_slot_usage()
