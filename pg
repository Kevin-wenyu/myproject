cmd_maintenance_check()
{
  q "SELECT schemaname, tablename,
       n_tup_ins, n_tup_upd, n_tup_del,
       n_dead_tup,
       last_vacuum, last_autovacuum, last_analyze, last_autoanalyze,
       CASE
         WHEN n_dead_tup > n_tup_upd * 0.1 AND last_vacuum < now() - interval '1 hour' THEN 'VACUUM NEEDED'
         WHEN n_dead_tup > 10000 AND last_vacuum < now() - interval '1 day' THEN 'VACUUM NEEDED'
         WHEN last_analyze < now() - interval '7 days' THEN 'ANALYZE NEEDED'
         ELSE 'OK'
       END AS maintenance_needed
     FROM pg_stat_user_tables
     WHERE (n_dead_tup > n_tup_upd * 0.1) OR (n_dead_tup > 10000) OR (last_analyze < now() - interval '7 days')
     ORDER BY n_dead_tup DESC
     LIMIT $TOP_N;"
}

cmd_cache_efficiency()
{
  q "SELECT 'Database' AS level,
       datname AS name,
       blks_read,
       blks_hit,
       CASE
         WHEN blks_hit + blks_read = 0 THEN 'N/A'
         ELSE round(100.0 * blks_hit / (blks_hit + blks_read), 2)::text || '%'
       END AS hit_ratio
     FROM pg_stat_database
     WHERE datname NOT IN ('template0', 'template1')
     UNION ALL
     SELECT 'Table' AS level,
       schemaname || '.' || relname AS name,
       heap_blks_read AS blks_read,
       heap_blks_hit AS blks_hit,
       CASE
         WHEN heap_blks_hit + heap_blks_read = 0 THEN 'N/A'
         ELSE round(100.0 * blks_hit / (heap_blks_hit + heap_blks_read), 2)::text || '%'
       END AS hit_ratio
     FROM pg_statio_user_tables
     WHERE (heap_blks_hit + heap_blks_read) > 0
     ORDER BY hit_ratio::NUMERIC DESC NULLS FIRST
     LIMIT $TOP_N;"
}

cmd_lock_graph()
{
  q "WITH RECURSIVE lock_chains AS (
       -- Base case: blocking relationships
       SELECT blocked.pid AS root_pid,
              blocked.pid,
              blocking.pid AS blocker_pid,
              1 AS level,
              ARRAY[blocked.pid] AS path,
              blocked.usename AS blocked_user,
              blocking.usename AS blocking_user,
              blocked.query AS blocked_query,
              blocking.query AS blocking_query,
              now() - blocked.query_start AS blocked_duration
       FROM pg_stat_activity blocked
       JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
       WHERE blocked.state = 'active'

       UNION ALL

       -- Recursive case: continue up the chain
       SELECT lc.root_pid,
              blocked.pid,
              blocking.pid AS blocker_pid,
              lc.level + 1,
              lc.path || blocked.pid,
              blocked.usename AS blocked_user,
              blocking.usename AS blocking_user,
              blocked.query AS blocked_query,
              blocking.query AS blocking_query,
              now() - blocked.query_start AS blocked_duration
       FROM lock_chains lc
       JOIN pg_stat_activity blocked ON blocked.pid = ANY(pg_blocking_pids(lc.pid))
       JOIN pg_stat_activity blocking ON blocking.pid = ANY(pg_blocking_pids(blocked.pid))
       WHERE blocked.state = 'active'
         AND NOT (blocked.pid = ANY(lc.path))  -- Prevent cycles
         AND lc.level < 10  -- Prevent infinite recursion
     )
     SELECT root_pid AS chain_root,
            pid AS blocked_pid,
            blocker_pid,
            level,
            blocked_user,
            blocking_user,
            blocked_duration,
            LEFT(blocked_query, 80) AS blocked_query
     FROM lock_chains
     ORDER BY chain_root, level, blocked_duration DESC;"
}

cmd_bloat_detail()
{
  q "SELECT tbloat.schemaname, tbloat.tablename,
       tbloat.bloat_pct,
       pg_size_pretty(tbloat.bloat_bytes) AS bloat_size,
       pg_size_pretty(pg_relation_size(tbloat.schemaname||'.'||tbloat.tablename)) AS table_size,
       tbloat.wastedbytes AS actual_wasted_bytes,
       tbloat.n_dead_tup,
       CASE
         WHEN tbloat.n_dead_tup > 10000 AND tbloat.last_vacuum < now() - interval '1 hour' THEN 'URGENT'
         WHEN tbloat.n_dead_tup > 5000 AND tbloat.last_vacuum < now() - interval '30 minutes' THEN 'HIGH'
         WHEN tbloat.bloat_pct > 30 THEN 'MEDIUM'
         ELSE 'LOW'
       END AS priority
     FROM (
       SELECT schemaname, tablename,
              CASE
                WHEN reltuples > 0 THEN
                  round(100 * (bs*tuple_hdr_width + tuple_data_width * reltuples - 8192)/(bs*relpages)::float, 2)
                ELSE 0
              END AS bloat_pct,
              CASE
                WHEN reltuples > 0 THEN
                  ceil((bs-tuple_hdr_width)*reltuples/bs) * pagesize - coalesce(table_len, 0)
                ELSE 0
              END AS bloat_bytes,
              CASE
                WHEN reltuples > 0 THEN
                  ceil((bs-tuple_hdr_width)*reltuples/bs) * pagesize - coalesce(table_len, 0)
                ELSE 0
              END AS wastedbytes,
              n_dead_tup,
              last_vacuum
       FROM (
         SELECT ceil(32613::float/(blksize-page_hdr))::int AS bs,
                blksize, tblpages, fillfactor,
                (tblpages-ceil(fillfactor*(tblpages-page_hdr)/(blksize-size_hdr-blksize/reltuples))) AS extra_pages,
                ceil(32613::float/(blksize-page_hdr))*(tblpages-fillfactor*(tblpages-page_hdr)/(blksize-size_hdr-blksize/reltuples)) AS bs_scanned,
                size_hdr, tblpages, page_hdr, tuple_hdr_width, tuple_data_width, reltuples, blksize,
                (reltuples*(tuple_hdr_width + tuple_data_width) + 2*bs) AS table_len, tblid, schemaname, tablename
         FROM (
           SELECT tbl.oid AS tblid, tbl.schemaname, tbl.tablename, stat.relpages, stat.reltuples,
             current_setting('block_size')::numeric AS blksize,
             CASE WHEN version()~'mingw32' OR version()~'64-bit|x86_64|ppc64|ia64|amd64' THEN 8 ELSE 4 END AS size_hdr,
             CASE WHEN SUBSTRING(SPLIT_PART(v, ' ', 2) FROM '#\".\"#' FOR '#') IN ('8.0','8.1','8.2') THEN 27 ELSE 23 END AS page_hdr,
             CASE WHEN MAX(coalesce(null_frac,0)) = 0 THEN 2 ELSE 6 END AS nulldatawidth_corrc,
             (CASE WHEN MAX(coalesce(null_frac,0)) = 0 THEN 2 ELSE 6 END) -
               (SELECT 1 + count(1)/8
                FROM pg_stats s2
                WHERE schemaname = s.schemaname
                  AND tablename = s.tablename
                  AND EXISTS (SELECT 1 FROM pg_stats s3
                              WHERE s3.schemaname = s.schemaname
                                AND s3.tablename = s.tablename
                                AND s3.attname = s.attname
                                AND NOT s3.null_frac = 0)
               ) AS nulldatawidth_corr,
             SUM((1-coalesce(s.null_frac, 0)) * coalesce(s.avg_width, 1024)) AS datawidth,
             MAX(case when atttypid in (1042,1043) then 1 else 0 end) AS is_char,
             MIN(case when atttypid in (21, 23, 25, 1042, 1043) then 13 else attlen end) AS min_col_width,
             MAX(case when atttypid in (21, 23, 25, 1042, 1043) then 13 else attlen end) AS max_col_width,
             ( 4 + nulldatawidth_corr
                + (abs(split_part(array_dims('{1}'::text[]),':',2)::smallint - 0) + 1) * 2
                + (case when atttypid in (1042,1043) then 1 else 0 end)
             ) AS tuple_hdr_width,
             ( 4 + nulldatawidth_corrc
                + (abs(split_part(array_dims('{1}'::text[]),':',2)::smallint - 0) + 1) * 2
                + (case when atttypid in (1042,1043) then 1 else 0 end)
             ) AS tuple_data_width
           FROM pg_attribute att
           JOIN pg_class tbl ON att.attrelid = tbl.oid
           JOIN pg_namespace ns ON tbl.relnamespace = ns.oid
           JOIN pg_stats s ON s.schemaname=ns.nspname
                            AND s.tablename = tbl.relname
                            AND s.attname = att.attname
           JOIN (SELECT schemaname, tablename, attname, c.oid FROM pg_stats s, pg_class c, pg_namespace n
                 WHERE schemaname = n.nspname AND c.relname = tablename AND n.oid = c.relnamespace
                 GROUP BY schemaname, tablename, attname, c.oid
                ) AS cs ON s.schemaname=cs.schemaname
                       AND s.tablename = cs.tablename
                       AND s.attname = cs.attname
                       AND att.attname = cs.attname
           JOIN pg_class stat ON tbl.oid = stat.oid
           JOIN pg_depend dep ON (dep.objid = tbl.oid AND dep.deptype = 'i')
           CROSS JOIN (SELECT setting AS v FROM pg_settings WHERE name='server_version') AS v
           WHERE tbl.relkind = 'r'
             AND att.attnum > 0
             AND NOT att.attisdropped
             AND s.schemaname NOT IN ('pg_catalog','information_schema')
           GROUP BY tbl.oid, tbl.schemaname, tbl.tablename, stat.relpages, stat.reltuples, v.v
         ) AS table_info
       ) AS tbloat
       LEFT JOIN pg_stat_user_tables ON pg_stat_user_tables.schemaname = tbloat.schemaname AND pg_stat_user_tables.tablename = tbloat.tablename
     ) AS detailed_bloat
     WHERE detailed_bloat.bloat_pct > 20  -- Only show tables with >20% bloat
     ORDER BY detailed_bloat.bloat_bytes DESC
     LIMIT $TOP_N;"
}

cmd_stats_check()
{
