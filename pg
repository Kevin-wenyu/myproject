cmd_slowlog_analysis()
{
  q "SELECT LEFT(query, 100) AS sample_query,
       count(*) AS execution_count,
       round(avg(total_time), 2) AS avg_time_ms,
       round(max(total_time), 2) AS max_time_ms,
       round(min(total_time), 2) AS min_time_ms,
       round(stddev(total_time), 2) AS stddev_time_ms
     FROM pg_stat_statements
     WHERE mean_time > 1000  -- Queries taking more than 1 second on average
     GROUP BY LEFT(query, 100)
     ORDER BY avg_time_ms DESC
     LIMIT $TOP_N;"
