cmd_long_transactions()
{
  local mins=${1:-5}
  q "SELECT pid, usename, application_name, client_addr::text,
       xact_start, now() - xact_start AS duration,
       state, LEFT(query, 100) AS query
     FROM pg_stat_activity
     WHERE xact_start IS NOT NULL
       AND now() - xact_start > interval '$mins minutes'
       AND state != 'idle in transaction'
     ORDER BY xact_start;"
}

cmd_session_stats()
{
  q "SELECT usename, application_name, state,
       count(*) AS sessions,
       count(*) FILTER(WHERE wait_event IS NOT NULL) AS waiting,
       ROUND(avg(now() - query_start)::numeric, 2) AS avg_duration_sec,
       max(now() - query_start) AS max_duration
     FROM pg_stat_activity
     WHERE state IS NOT NULL
     GROUP BY usename, application_name, state
     ORDER BY count(*) DESC;"
}

cmd_wal_rate()
{
  local window=${1:-5}
  q "WITH wal_start AS (
       SELECT pg_current_wal_lsn() AS start_lsn
     ),
     wal_end AS (
       SELECT pg_current_wal_lsn() AS end_lsn
     )
     SELECT pg_size_pretty(pg_wal_lsn_diff(end_lsn, start_lsn)) AS wal_generated,
            pg_wal_lsn_diff(end_lsn, start_lsn) AS bytes,
            ROUND(pg_wal_lsn_diff(end_lsn, start_lsn) / $window) AS bytes_per_sec
       FROM wal_start, wal_end
       WHERE pg_current_wal_lsn() != (SELECT start_lsn FROM wal_start);"
}

cmd_bgwriter()
{
  q "SELECT checkpoints_timed, checkpoints_req,
       CASE WHEN checkpoints_timed + checkpoints_req > 0
            THEN round(100.0 * checkpoints_timed / (checkpoints_timed + checkpoints_req), 2)
            ELSE 0 END AS timed_ratio,
       buffers_checkpoint, buffers_clean, buffers_backend,
       buffers_alloc,
       pg_size_pretty(buffers_checkpoint*8192) AS checkpoint_bytes,
       pg_size_pretty(buffers_clean*8192) AS clean_bytes,
       pg_size_pretty(buffers_backend*8192) AS backend_bytes,
       pg_size_pretty(buffers_alloc*8192) AS alloc_bytes
     FROM pg_stat_bgwriter;"
}

cmd_db_growth()
{
