# ============================================
# MAIN DISPATCHER
# ============================================

dispatch_command()
{
  local cmd="$1"
  shift

  case "$cmd" in
    ps|sessions)           cmd_ps "$@" ;;
    running)               cmd_running "$@" ;;
    blocking|blocked)      cmd_blocking "$@" ;;
    locks)                 cmd_locks "$@" ;;
    kill)                  cmd_kill "$@" ;;
    cancel)                cmd_cancel "$@" ;;
    sql|fulltext)          cmd_sql "$@" ;;

    slow|slow_queries)     cmd_slow "$@" ;;
    top_time|top_queries)  cmd_top_time "$@" ;;
    top_calls)             cmd_top_calls "$@" ;;
    top_io)                cmd_top_io "$@" ;;
    query_history)         cmd_query_history "$@" ;;

    table_size|tables_size) cmd_table_size "$@" ;;
    index_size)            cmd_index_size "$@" ;;
    bloat|dead_tuples)     cmd_bloat "$@" ;;
    unused_indexes)        cmd_unused_indexes "$@" ;;
    duplicate_indexes)     cmd_duplicate_indexes "$@" ;;
    missing_indexes)       cmd_missing_indexes "$@" ;;

    vacuum_status)         cmd_vacuum_status "$@" ;;
    vacuum_progress)       cmd_vacuum_progress "$@" ;;

    conn|connections)      cmd_conn "$@" ;;
    conn_limit)            cmd_conn_limit "$@" ;;
    idle_tx|idle_in_tx)    cmd_idle_tx "$@" ;;

    cache_hit)             cmd_cache_hit "$@" ;;
    io_stats)              cmd_io_stats "$@" ;;
    wait_events)           cmd_wait_events "$@" ;;
    temp_files)            cmd_temp_files "$@" ;;

    repl|replication)      cmd_repl "$@" ;;
    repl_lag|replication_lag) cmd_repl_lag "$@" ;;
    slot|slots)            cmd_slot "$@" ;;

    wal|wal_info)          cmd_wal "$@" ;;
    checkpoint)            cmd_checkpoint "$@" ;;

    db_size|database_size) cmd_db_size "$@" ;;
    ts_size|tablespace_size) cmd_ts_size "$@" ;;
    schema_size)           cmd_schema_size "$@" ;;

    config)                cmd_config "$@" ;;
    config_diff)           cmd_config_diff "$@" ;;
    reload|reload_config)  cmd_reload "$@" ;;

    tables)                cmd_tables "$@" ;;
    indexes)               cmd_indexes "$@" ;;
    views)                 cmd_views "$@" ;;
