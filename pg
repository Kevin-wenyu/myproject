       parent.relname AS table_name,
       t.relname AS toast_table,
       pg_size_pretty(pg_relation_size(t.schemaname||'.'||t.relname)) AS toast_size,
       pg_size_pretty(pg_total_relation_size(parent.schemaname||'.'||parent.relname)) AS total_table_size
     FROM pg_class parent
     JOIN pg_namespace n ON parent.relnamespace = n.oid
     JOIN pg_class t ON parent.reltoastrelid = t.oid
     WHERE n.nspname NOT IN ('pg_catalog', 'information_schema')
       AND pg_relation_size(t.schemaname||'.'||t.relname) > 1048576
     ORDER BY pg_relation_size(t.schemaname||'.'||t.relname) DESC;"
