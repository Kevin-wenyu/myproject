cmd_explain()
{
  local sql="$*"
  [ -z "$sql" ] && { echo "Usage: $EXEC_NAME explain \"<SQL>\""; return 1; }

  # Basic SQL validation to prevent harmful statements
  local sql_upper=$(echo "$sql" | tr '[:lower:]' '[:upper:]')
  if [[ "$sql_upper" =~ ^(INSERT|UPDATE|DELETE|DROP|CREATE|ALTER|TRUNCATE|GRANT|REVOKE|COMMIT|ROLLBACK|BEGIN|START TRANSACTION|SET|SHOW|RESET) ]]; then
    echo "Error: Only SELECT statements are allowed in explain mode for security reasons" >&2
    return 1
  fi

  # Sanitize the input before passing to EXPLAIN
  local sanitized_sql=$(q_sanitize "$sql")
  q "EXPLAIN (ANALYZE, BUFFERS, FORMAT TEXT) $sanitized_sql;"
}

