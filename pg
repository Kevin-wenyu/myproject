cmd_table_gaps()
{
  local limit=${1:-$TOP_N}
  q "SELECT schemaname, relname AS table_name,
       seq_scan, idx_scan, n_live_tup,
       CASE
         WHEN idx_scan = 0 AND seq_scan > 100 THEN 'NO INDEX'
         WHEN seq_scan > idx_scan * 10 THEN 'HIGH SEQ SCAN'
         WHEN seq_scan > 100 THEN 'MODERATE'
