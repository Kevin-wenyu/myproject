cmd_plan_analysis()
{
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed or not enabled."
    echo "Run: CREATE EXTENSION IF NOT EXISTS pg_stat_statements;"
    echo "And add pg_stat_statements to shared_preload_libraries in postgresql.conf"
    return 1
  fi

  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns || {
    echo "Error: Could not initialize pg_stat_statements columns."
    return 1
  }

  q "SELECT LEFT(query, 120) AS query_snippet,
       calls,
       round(${PGS_TOTAL_COL}) AS total_time_ms,
       round(${PGS_MEAN_COL}) AS mean_time_ms,
       round(${PGS_MAX_COL}) AS max_time_ms,
       rows,
       round(rows::numeric / calls, 2) AS rows_per_call,
       round(${PGS_TOTAL_COL} / NULLIF(shared_blks_hit + shared_blks_read, 0), 2) AS time_per_block_ms
     FROM pg_stat_statements
     WHERE ${PGS_TOTAL_COL} > 1000  -- Only show queries taking more than 1 second cumulatively
     ORDER BY ${PGS_TOTAL_COL} DESC
     LIMIT $limit;"
}

cmd_execution_profile()
{
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed or not enabled."
    return 1
  fi

  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns || {
    echo "Error: Could not initialize pg_stat_statements columns."
    return 1
  }

  q "SELECT LEFT(query, 100) AS query_snippet,
       calls,
       round(${PGS_TOTAL_COL}) AS total_time_ms,
       round(${PGS_MEAN_COL}) AS mean_time_ms,
       round(${PGS_MAX_COL}) AS max_time_ms,
       shared_blks_read + local_blks_read + temp_blks_read AS total_reads,
       shared_blks_hit + local_blks_hit AS total_hits,
       round((shared_blks_hit + local_blks_hit)::numeric * 100 /
             NULLIF(shared_blks_hit + local_blks_hit + shared_blks_read + local_blks_read, 0), 2) AS io_efficiency_pct,
       round((${PGS_TOTAL_COL} / NULLIF(calls, 0))::numeric, 2) AS time_per_call_ms
     FROM pg_stat_statements
     WHERE calls > 10  -- Only show queries executed more than 10 times
     ORDER BY ${PGS_TOTAL_COL} DESC
     LIMIT $limit;"
}

cmd_histogram_stats()
{
  local table_name="$1"
  if [ -z "$table_name" ]; then
    echo "Usage: $EXEC_NAME histogram_stats <table_name>"
    echo "Note: This command requires the pg_stats_ext extension for advanced histogram analysis"
    return 1
  fi

  local sanitized_table=$(q_sanitize "$table_name")

  # Verify table name format
  if [[ ! "$sanitized_table" =~ ^[a-zA-Z0-9_]+$ ]]; then
    echo "Error: Invalid table name format" >&2
    return 1
  fi

  q "SELECT schemaname, tablename, attname, inherited,
       null_frac, avg_width, n_distinct, correlation,
       most_common_vals, most_common_freqs,
       histogram_bounds
     FROM pg_stats
     WHERE tablename = '$sanitized_table'
       AND schemaname NOT IN ('pg_catalog', 'information_schema')
     ORDER BY schemaname, tablename, attname
     LIMIT 20;"
}

cmd_parallel_efficiency()
{
  if [ -z "$(extension_installed pg_stat_statements)" ]; then
    echo "Error: pg_stat_statements extension not installed or not enabled."
    return 1
  fi

  local limit=${1:-$TOP_N}
  init_pg_stat_statements_columns || {
    echo "Error: Could not initialize pg_stat_statements columns."
    return 1
  }

  q "SELECT LEFT(query, 100) AS query_snippet,
       calls,
       round(${PGS_TOTAL_COL}) AS total_time_ms,
       shared_blks_dirtied, shared_blks_written,
       temp_blks_written,
       blk_read_time, blk_write_time
     FROM pg_stat_statements
     WHERE shared_blks_dirtied > 0 OR temp_blks_written > 0
     ORDER BY shared_blks_dirtied DESC
     LIMIT $limit;"
}

